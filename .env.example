APP_NAME="ExpenseBuddy"
APP_BRAND_NAME="ExpenseBuddy"
APP_BRAND_TAGLINE="Your Personal Finance Companion"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=expensebuddy
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

LEDGER_ALLOW_NEGATIVE_BALANCES=false

# Optional: load sample banks, accounts, and transactions (fresh DB only)
# SEED_DEMO_DATA=true
